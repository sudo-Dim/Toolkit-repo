        "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
        "Origin": "https://account.mail.ru",
        "Referer": "https://account.mail.ru/recovery"
      },
      "body": "email={emaillower}&htmlencoded=false",
      "exists": [{"all": [{"status": [200]}, {"json": "status", "eq": 200}]}],
      "notexists": [],
      "reliability": "medium"
    },
    {
      "name": "Rambler",
      "category": "Email Provider",
      "method": "POST",
      "url": "https://id.rambler.ru/jsonrpc",
      "content_type": "json",
      "headers": {
        "Accept": "*/*",
        "Content-Type": "application/json",
        "Origin": "https://id.rambler.ru",
        "Referer": "https://id.rambler.ru/champ/registration"
      },
      "body": {"method": "Rambler::Id::get_email_account_info", "params": [{"email": "{email}"}], "rpc": "2.0"},
      "exists": [{"json": "result.result.exists", "in": [1]}],
      "notexists": [{"json": "result.result.exists", "in": [0]}],
      "reliability": "medium"
    },
    {
      "name": "Flickr",
      "category": "Photo",
      "method": "GET",
      "url": "https://identity-api.flickr.com/migration?email={email}",
      "content_type": "none",
      "headers": {
        "Accept": "*/*",
        "Referer": "https://identity.flickr.com/login",
        "Origin": "https://identity.flickr.com"
      },
      "exists": [{"json": "state_code", "eq": "5"}],
      "notexists": [],
      "reliability": "medium",
      "notes": "Flickr/Yahoo-Identitaet: state_code 5 = vorhanden."
    },
    {
      "name": "Nimble",
      "category": "CRM",
      "method": "GET",
      "url": "https://www.nimble.com/lib/register.php?email={email}",
      "content_type": "none",
      "headers": {
        "Accept": "application/json, text/javascript, */*; q=0.01",
        "X-Requested-With": "XMLHttpRequest",
        "Referer": "https://www.nimble.com/"
      },
      "exists": [{"body_contains": "already registered"}],
      "notexists": [{"body_equals": "true"}],
      "reliability": "medium"
    }
  ],
